{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "track-to-inventory-web",
  "main": "./workers/app.ts",
  "compatibility_date": "2026-04-03",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./build/client",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  }
}
